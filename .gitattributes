# Force CRLF for Windows batch + PowerShell scripts. Without this, GitHub's
# "Download ZIP" (and `git archive`) can serve LF-only .bat files, which makes
# cmd.exe mis-parse labels / IF blocks and mangle the on-screen text.
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

*.md        text
*.txt       text

# Binary assets — never normalize line endings or merge
*.ico       binary
*.png       binary
*.jpg       binary
*.gif       binary
*.zip       binary
*.exe       binary
